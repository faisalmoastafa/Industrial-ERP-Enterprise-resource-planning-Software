APP_NAME="Industrial ERP System"
APP_ENV=production
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=false
APP_URL=https://industrial-erp-enterprise-resource-planning-soft-production.up.railway.app

LOG_CHANNEL=stderr
